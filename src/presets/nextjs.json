{
  "thresholds": {
    "cognitiveComplexity": 15,
    "cyclomaticComplexity": 10,
    "newAnyCount": 0,
    "newTsIgnoreCount": 0,
    "coverageDelta": 0,
    "duplicationLines": 30,
    "functionLength": 80,
    "parameterCount": 4
  },
  "ignore": [
    "**/*.test.{ts,tsx}",
    "**/__tests__/**",
    "**/*.stories.{ts,tsx}",
    "**/migrations/**",
    "**/.next/**",
    "**/generated/**"
  ],
  "maxRefactorAttempts": 2,
  "preCommit": {
    "enabled": [
      "cognitive",
      "cyclomatic",
      "type-safety",
      "duplication",
      "transaction-required",
      "revalidate-required",
      "n-plus-one-query",
      "migration-safety",
      "silent-catch",
      "hallucinated-import",
      "shallow-module",
      "function-length",
      "parameter-count",
      "secret-in-diff",
      "injection",
      "new-dependency"
    ],
    "parallel": true,
    "timeoutMs": 30000
  },
  "tsxOverrides": {
    "cognitiveComplexity": 20,
    "ignoreJsxExpressionContainerSimple": true
  }
}
